    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"cdi_indicator = CDIIndicator(                         # Carregamos um objeto do CDIIndicator, que é a classe responsável por lidar com os dados do CDI.\\n\",\n",
    "    \"    raw_storage=RawStorageFactory.create_storage(\\\"json\\\", \\\"cdi\\\"),\\n\",\n",
