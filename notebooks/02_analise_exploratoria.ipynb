    "   \"source\": [\n",
    "    \"from src.config import pr_root\\n\",\n",
    "    \"from src.indicators.cdi_indicator import CDIIndicator\\n\",\n",
    "    \"from src.storage import RawStorageFactory, ProcessedStorageFactory, cdi_schema\\n\",\n",
    "    \"import notebooks.src.analysis.descriptive as descriptive\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 1\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": [\n",
    "    \"# 2. Análise Exploratória dos Dados\\n\",\n",
    "    \"\\n\",\n",
    "    \"Agora que conhecemos os dados, vamos começar com uma análise exploratória de todos os dados que temos disponíveis.\\n\",\n",
    "    \"\\n\",\n",
    "    \"## A função\\n\",\n",
    "    \"\\n\",\n",
    "    \"A função a seguir será a utilizada para gerar toda a análise exploratória inicial. Ela é implementadaHHH\"\n",
    "   ],\n",
    "   \"id\": \"a6f0cb91ed851741\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-01T20:23:16.592161Z\",\n",
    "     \"start_time\": \"2026-03-01T20:23:16.585221Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"def exploratory_analysis(indicator, column=None):\\n\",\n",
    "    \"    df = indicator.processed_storage.get_data()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    numeric_cols = df.select_dtypes(include=['float64', 'int64']).columns\\n\",\n",
    "    \"    column = column or numeric_cols[0]\\n\",\n",
    "    \"    data = df[column].dropna().tolist()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    stats = descriptive.summary(data)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\"Resumo Estatístico - '{column}':\\\")\\n\",\n",
    "    \"    for key, value in stats.items():\\n\",\n",
    "    \"        print(f\\\"  {key:12s}: {value:.4f}\\\")\"\n",
    "   ],\n",
    "   \"id\": \"f54c78a6d1de8e6e\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 2\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
